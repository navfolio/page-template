---
const builtAt = new Date().toISOString().slice(0, 10);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Hello Navfolio Page Module</title>
  </head>
  <body>
    <main class="page-shell">
      <p class="eyebrow">Navfolio Page Module</p>
      <h1>Hello from a custom page module.</h1>
      <p class="lede">
        This route is injected from <code>@navfolio/page-template</code>. Replace this Astro
        entrypoint with your own layout, data, and styles.
      </p>
      <dl>
        <div>
          <dt>Default route</dt>
          <dd><code>/hello-page</code></dd>
        </div>
        <div>
          <dt>Build date</dt>
          <dd>{builtAt}</dd>
        </div>
      </dl>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    min-height: 100vh;
    background: #f7f5ef;
    color: #1f2a22;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .page-shell {
    display: grid;
    align-content: center;
    min-height: 100vh;
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 24px;
  }

  .eyebrow {
    margin: 0 0 16px;
    color: #667a6d;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  .lede {
    max-width: 620px;
    margin: 24px 0 32px;
    color: #46534a;
    font-size: 1.08rem;
    line-height: 1.8;
  }

  dl {
    display: grid;
    gap: 12px;
    margin: 0;
  }

  dl > div {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    border-top: 1px solid rgb(31 42 34 / 15%);
    padding-top: 12px;
  }

  dt {
    color: #667a6d;
    font-weight: 700;
  }

  dd {
    margin: 0;
  }

  code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
</style>
