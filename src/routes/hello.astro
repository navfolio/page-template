---
import { getHtmlLang, getI18n, getSiteConfig } from 'virtual:navfolio/page-runtime';

const builtAt = new Date().toISOString().slice(0, 10);
const siteConfig = await getSiteConfig();
const htmlLang = getHtmlLang(siteConfig);
const i18n = getI18n(siteConfig);
---

<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{i18n.t('template.documentTitle')}</title>
  </head>
  <body>
    <main class="page-shell">
      <p class="eyebrow">{i18n.t('template.eyebrow')}</p>
      <h1>{i18n.t('template.heading')}</h1>
      <p class="lede">
        {i18n.t('template.description')}
      </p>
      <dl>
        <div>
          <dt>{i18n.t('template.defaultRoute')}</dt>
          <dd><code>/hello-page</code></dd>
        </div>
        <div>
          <dt>{i18n.t('template.buildDate')}</dt>
          <dd>{builtAt}</dd>
        </div>
      </dl>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    min-height: 100vh;
    background: #f7f5ef;
    color: #1f2a22;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .page-shell {
    display: grid;
    align-content: center;
    min-height: 100vh;
    max-width: 760px;
    margin: 0 auto;
    padding: 48px 24px;
  }

  .eyebrow {
    margin: 0 0 16px;
    color: #667a6d;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  .lede {
    max-width: 620px;
    margin: 24px 0 32px;
    color: #46534a;
    font-size: 1.08rem;
    line-height: 1.8;
  }

  dl {
    display: grid;
    gap: 12px;
    margin: 0;
  }

  dl > div {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    border-top: 1px solid rgb(31 42 34 / 15%);
    padding-top: 12px;
  }

  dt {
    color: #667a6d;
    font-weight: 700;
  }

  dd {
    margin: 0;
  }

  code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }
</style>
